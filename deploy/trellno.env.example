# Trellno server environment — copy to /etc/trellno.env and fill in.
# Keep it root-readable only:  sudo chmod 600 /etc/trellno.env

# The server renders its own local file store (the canonical board data).
TRELLO_BACKEND=local
TRELLO_LOCAL_ROOT=/srv/trellno/data

# API token every client must present (Bearer header or ?token=).
# Mint one:  openssl rand -base64 32
TRELLNO_TOKEN=change-me

# Public domain Caddy serves — accepted in the Host header (DNS-rebinding
# guard); must match the Caddyfile site address.
TRELLNO_DOMAIN=trellno.example.com
